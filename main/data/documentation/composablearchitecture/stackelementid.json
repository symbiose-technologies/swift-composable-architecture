{"primaryContentSections":[{"declarations":[{"tokens":[{"text":"struct","kind":"keyword"},{"kind":"text","text":" "},{"text":"StackElementID","kind":"identifier"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackState"},{"type":"text","text":" type creates instances of this identifier when new elements are added to"},{"text":" ","type":"text"},{"type":"text","text":"the stack. This makes it possible to easily look up specific elements in the stack without"},{"type":"text","text":" "},{"type":"text","text":"resorting to positional indices, which can be error prone, especially when dealing with async"},{"text":" ","type":"text"},{"type":"text","text":"effects."}]},{"inlineContent":[{"text":"In production environments (e.g. in Xcode previews, simulators and on devices) the identifier","type":"text"},{"type":"text","text":" "},{"type":"text","text":"is backed by a randomly generated UUID, but in tests a deterministic, generational ID is used."},{"text":" ","type":"text"},{"type":"text","text":"This allows you to predict how IDs will be created and allows you to write tests for how"},{"type":"text","text":" "},{"text":"features behave in the stack.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Test","func basics() {","  var path = StackState<Int>()","  path.append(42)","  XCTAssertEqual(path[id: 0], 42)","  path.append(1729)","  XCTAssertEqual(path[id: 1], 1729)","","  path.removeAll()","  path.append(-1)","  XCTAssertEqual(path[id: 2], -1)","}"]},{"inlineContent":[{"text":"Notice that after removing all elements and appending a new element, the ID generated was 2 and","type":"text"},{"text":" ","type":"text"},{"type":"text","t