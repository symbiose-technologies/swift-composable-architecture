istic, generational ID is used.","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"This allows you to predict how IDs will be created and allows you to write tests for how"},{"type":"text","text":" "},{"type":"text","text":"features behave in the stack."}]},{"type":"codeListing","code":["@Test","func basics() {","  var path = StackState<Int>()","  path.append(42)","  XCTAssertEqual(path[id: 0], 42)","  path.append(1729)","  XCTAssertEqual(path[id: 1], 1729)","","  path.removeAll()","  path.append(-1)","  XCTAssertEqual(path[id: 2], -1)","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Notice that after removing all elements and appending a new element, the ID generated was 2 and"},{"text":" ","type":"text"},{"text":"did not go back to 0. This is because in tests the IDs are ","type":"text"},{"inlineContent":[{"text":"generational","type":"text"}],"type":"emphasis"},{"type":"text","text":", which means they"},{"type":"text","text":" "},{"type":"text","text":"keep counting up, even if you remove elements from the stack."}]}]}],"abstract":[{"type":"text","text":"An opaque type that identifies an element of "},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackState","type":"reference"},{"text":".","type":"text"}],"variants":[{"paths":["\/documentation\/composablearchitecture\/stackelementid"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://ComposableArchitecture/documentation/ComposableArchitecture/StackElementID/ExpressibleByIntegerLiteral-Implementations":{"type":"topic","title":"ExpressibleByIntegerLiteral Implementations","abstract":[],"kind":"article","url":"\/documentation\/composablearchitecture\/stackelementid\/expressiblebyintegerliteral-implementations","role":"collectionGroup","identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/StackElementID\/ExpressibleByIntegerLiteral-Implementations"},"doc://ComposableA