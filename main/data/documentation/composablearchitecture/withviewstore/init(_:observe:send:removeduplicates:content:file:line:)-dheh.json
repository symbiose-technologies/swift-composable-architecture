text":"Content"},{"text":", ","kind":"text"},{"text":"file","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:s12StaticStringV","text":"StaticString"},{"kind":"text","text":" = "},{"kind":"keyword","text":"#fileID"},{"kind":"text","text":", "},{"text":"line","kind":"externalParam"},{"text":": ","kind":"text"},{"kind":"typeIdentifier","preciseIdentifier":"s:Su","text":"UInt"},{"text":" = ","kind":"text"},{"text":"#line","kind":"keyword"},{"kind":"text","text":")"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"content":[{"inlineContent":[{"type":"text","text":"A store."}],"type":"paragraph"}],"name":"store"},{"name":"toViewState","content":[{"inlineContent":[{"text":"A function that transforms store state into observable view state. All","type":"text"},{"type":"text","text":" "},{"type":"text","text":"changes to the view state will cause the "},{"type":"codeVoice","code":"WithViewStore"},{"text":" to re-compute its view.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A function that transforms view actions into store action.","type":"text"}],"type":"paragraph"}],"name":"fromViewAction"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A function to determine when two ","type":"text"},{"type":"codeVoice","code":"ViewState"},{"type":"text","text":" values are equal. When values"},{"text":" ","type":"text"},{"type":"text","text":"are equal, repeat view computations are removed."}]}],"name":"isDuplicate"},{"content":[{"type":"paragraph","inlineContent":[{"text":"A function that can generate content from a view store.","type":"text"}]}],"name":"content"}]},{"content":[{"anchor":"discussion","text":"Discussion","level":2,"type":"heading"},{"inlineContent":[{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/WithViewStore","isActive":true,"type":"reference"},{"text":" will re-compute its body for ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"any"}]},{"type":"text","text":" change to the state it holds. Often the"},{"text":" ","type":"text"},{"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","isActive":true,"type":"reference"},{"type":"text","text":" that we want to observe holds onto a lot more state than is necessary to render a"},{"type":"text","text":" "},{"text":"view. It may hold onto the state of child features, or internal state for its logic.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"It can be important to transform the ","type":"text"},{"isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Store","type":"reference"},{"type":"text","text":"’s state into something smaller for observation."},{"type":"text","text":" "},{"type":"text","text":"This will help minimize the number of times your view re-computes its body, and can even avoid"},{"type":"text","text":" "},{"type":"text","text":"certain SwiftUI bugs that happen due to over-rendering."}]},{"inlineContent":[{"type":"text","text":"The way to do this is to use the "},{"type":"codeVoice","code":"observe"},{"text":" argument of this initializer. It allows you to","type":"text"},{"text":" ","type":"text"},{"type":"text","text":"turn the full state into a smaller data type, and only changes to that data type will trigger"},{"type":"text","text":" "},{"text":"a body re-computation.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if your application uses a tab view, then the root state may hold the state"},{"text":" ","type":"text"},{"type":"text","text":"for each tab as well as the currently selected tab:"}]},{"type":"codeListing","syntax":"swift","code":["@Reducer","struct AppFeature {","  enum Tab { case activity, search, profile }","  struct State {","    var activity: Activity.State","    var search: Search.State","    var profile: Profile.State","    var selectedTab: Tab","  }","  \/\/ ...","}"]},{"inlineContent":[{"type":"text","text":"In order to construct a tab view you need to observe this state because changes to"},{"text":" ","type":"text"},{"type":"codeVoice","code":"selectedTab"},{"text":" need to make SwiftUI update the visual state of the UI. However, you do not","type":"text"},{"text":" ","type":"text"},{"text":"need to observe changes to ","type":"text"},{"type":"codeVoice","code":"activity"},{"type":"text","text":", "},{"code":"search","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"profile"},{"text":". Those are only necessary for","type":"text"},{"type":"text","text":" "},{"type":"text","text":"those child features, and changes to that state should not cause our tab view to re-compute"},{"text":" ","type":"text"},{"type":"text","text":"itself."}],"type":"paragraph"},{"type":"codeListing","code":["struct AppView: View {","  let store: StoreOf<AppFeature>","","  var body: some View {","    WithViewStore(self.store, observe: \\.selectedTab) { viewStore in","      TabView(selection: viewStore.binding(send: { .tabSelected($0) }) {","        ActivityView(","          store: self.store.scope(state: \\.activity, action: \\.activity)","        )","        .tag(AppFeature.Tab.activity)","        SearchView(","          store: self.store.scope(state: \\.search, action: \\.search)","        )","        .tag(AppFeature.Tab.search)","        ProfileView(","          store: self.store.scope(state: \\.profile, action: \\.profile)","        )","        .tag(AppFeature.Tab.profile)","      }","    }","  }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"To read more about this performance technique, read the "},{"type":"reference","isActive":true,"identifier":"doc:\/\/ComposableArchitecture\/documentation\/ComposableArchitecture\/Performance"},{"text":" article.","type":"text"}]}],"kind":"content"}]